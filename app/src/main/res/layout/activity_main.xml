<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Passepartout"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFB400"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daily task alarm"
        android:textSize="16sp"
        android:textColor="#aaaaaa"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#4ade80"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginBottom="48dp"
        android:lineSpacingExtra="6dp"/>

    <Button
        android:id="@+id/test_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Test: Show Task Screen Now"
        android:backgroundTint="#3b82f6"
        android:textColor="#ffffff"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/test_notif_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Test: Simulate Real Alarm"
        android:backgroundTint="#6b7280"
        android:textColor="#ffffff"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/view_log_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="View Alarm Log"
        android:backgroundTint="#374151"
        android:textColor="#ffffff"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="The alarm fires automatically at 06:00 every morning.\nNo action needed from you."
        android:textColor="#666666"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
