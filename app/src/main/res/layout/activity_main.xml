<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_vertical"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Passepartout"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#FFB400"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Task alarm"
        android:textSize="16sp"
        android:textColor="#aaaaaa"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Session ID (PHPSESSID)"
        android:textColor="#eeeeee"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/session_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Paste your PHPSESSID here"
        android:textColor="#ffffff"
        android:textColorHint="#666666"
        android:background="#16213e"
        android:padding="16dp"
        android:inputType="text"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/save_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Save &amp; Schedule 06:00 Alarm"
        android:backgroundTint="#FFB400"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/test_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Test: Show Task Screen Now"
        android:backgroundTint="#3b82f6"
        android:textColor="#ffffff"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#aaaaaa"
        android:textSize="13sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="To get your session ID: log into Passepartout in Chrome on your phone, open DevTools (or use the push-debug page), and copy the PHPSESSID cookie value."
        android:textColor="#666666"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
